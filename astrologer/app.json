{
  "expo": {
    "name": "Aroha Astrology — Astrologer",
    "slug": "aroha-astrology-astrologer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "arohaastrology-astro",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#11131A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.arohaastrology.astrologer"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#11131A"
      },
      "package": "com.arohaastrology.astrologer"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
